{
  "name": "lms-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "bun run db:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:version": "bunx --bun prisma version",
    "prisma:format": "bunx --bun prisma format",
    "prisma:validate": "bunx --bun prisma validate",
    "db:generate": "bunx --bun prisma generate",
    "db:push": "bunx --bun prisma db push",
    "db:pull": "bunx --bun prisma db pull",
    "db:migrate": "bunx --bun prisma migrate dev",
    "db:migrate:deploy": "bunx --bun prisma migrate deploy",
    "db:migrate:status": "bunx --bun prisma migrate status",
    "db:reset": "bunx --bun prisma migrate reset",
    "db:seed": "bunx --bun prisma db seed",
    "db:studio": "bunx --bun prisma studio",
    "db:setup": "bun run db:migrate && bun run db:generate && bun run db:seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.1",
    "dotenv": "^17.3.1",
    "isomorphic-dompurify": "^3.10.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "next-cloudinary": "^6.17.5",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
